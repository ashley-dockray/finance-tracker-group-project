from datetime import datetime

# this is the base section of the program
class Transaction:
    def __init__(self, transaction_num, date, amount, description):
        if transaction_num == "":

            raise ValueError("ID cannot be empty")

        if type(date)!= datetime:
            raise ValueError("there is no date datetime ")
        if amount < 0:
            raise ValueError("There must be a positive amount ")
        if description == "":
            raise ValueError(" there must be a description")

        self.__id = transaction_num
        self.__date = date

        self.__amount = amount
        self.__description = description

## getters and setters

### returns the transaction number 
    def get_id(self):
        return self.__id

### if value is not empty the function sets a new ID
    def set_id(self, value):
        if value != "":
            self.__id = value

    def get_amount(self):
        return self.__amount

## all functions set the amount and then the other function gets the amount

    def set_amount(self, value):
        if value >= 0:
            self.__amount = value

    def get_description(self):
        return self.__description

    def set_description(self, value):
        if value != "":
            self.__description = value

###merges all data and adds it to one function to display it
    def display_details(self):
        return f"{self.__id} | {self.__date} | {self.__amount} | {self.__description}"



### sub class for all income
class Income(Transaction):
    def __init__(self, transaction_id, date, amount, description, source, is_taxable):
        super().__init__(transaction_id, date, amount, description)

        self.__source = source

##### stores if income is taxable
        self.__is_taxable = is_taxable


#### outputs all income data including base class details
    def display_details(self):
        return super().display_details() + f" | Source: {self.__source} | Taxable: {self.__is_taxable}"
